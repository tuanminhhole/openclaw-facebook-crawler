{
  "name": "openclaw-facebook-crawler",
  "version": "1.0.1",
  "description": "Facebook group motorbike listing crawler — filters individual sellers, location-aware, cron-integrated",
  "main": "index.js",
  "author": "tuanminhhole",
  "type": "module",
  "exports": "./index.js",
  "sideEffects": false,
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "package.json",
    "README.md", "config.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24",
      "minGatewayVersion": "2026.3.24"
    },
    "build": {
      "entry": "./index.js",
      "openclawVersion": "2026.3.24",
      "pluginSdkVersion": "2026.3.24"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
